/**
 * probe syscall_any - Record entry into a syscall
 *
 * @syscall_nr: number of the syscall
 * @name: name of the syscall
 *
 * Context: The process performing the syscall
 *
 * Prefers kernel.tracepoint("sys_enter") when vmlinux.h BTF tracepoints
 * are available; falls back to kernel.trace("sys_enter") (kernel 3.5+).
 */
probe syscall_any = kernel.tracepoint("sys_enter")!, kernel.trace("sys_enter")
{
	@__set_syscall_pt_regs
	if (@defined($arg2))
		syscall_nr = $arg2
	else
		syscall_nr = $id
	name = syscall_name(syscall_nr)
}

/**
 * probe syscall_any.return - Record exit from a syscall
 *
 * @syscall_nr: number of the syscall
 * @name: name of the syscall
 * @retval: return value of the syscall
 *
 * Context: The process performing the syscall
 *
 * Prefers kernel.tracepoint("sys_exit") when vmlinux.h BTF tracepoints
 * are available; falls back to kernel.trace("sys_exit") (kernel 3.5+).
 */
probe syscall_any.return = kernel.tracepoint("sys_exit")!, kernel.trace("sys_exit")
{
	@__set_syscall_pt_regs
	syscall_nr = _stp_syscall_nr()
	name = syscall_name(_stp_syscall_nr())
	if (@defined($arg2))
		retval = $arg2
	else
		retval = $ret
}
