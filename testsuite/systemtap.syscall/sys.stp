global target_pid = 0

probe procfs("target_pid").write {
	target_pid = strtol($value, 10)
        printf("resetting target_pid = %d", target_pid)
}

probe syscall.* ? {
	if (pid() == target_pid && execname() != "bash") {
		printf("%s: %s (%s) = ", execname(), name, argstr)
		syscall_nr = _stp_syscall_nr()
		if (! syscall_map(syscall_name(syscall_nr), name))
			printf(" [ ERROR: Unmatched syscalls %s vs. %s (%d) ] ", syscall_name(syscall_nr), name, syscall_nr)
	}
}

probe syscall.*.return ? {
	if (pid() == target_pid && execname() != "bash") {
		printf("%s\n", retstr)
	}
}
