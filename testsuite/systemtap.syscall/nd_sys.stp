global target_pid = 0

probe procfs("target_pid").write {
	target_pid = strtol($value, 10)
        printf("resetting target_pid = %d\n", target_pid)        
}

probe nd_syscall.* ? {
        if (pid() == target_pid && execname() != "bash") {
                printf("%s: %s (%s) = ", execname(), name, argstr)
                if (name == "exit_group" || name == "exit")
                        printf("?\n")
        }
}

probe nd_syscall.*.return ? {
	if (pid() == target_pid && execname() != "bash") {
		printf("%s\n", retstr)
	}
}
