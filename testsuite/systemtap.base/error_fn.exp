# check that errors in nested functions are not lost on return
# bugzilla 6529

set test "error_fn"

foreach runtime [get_runtime_list] {
    if {$runtime != ""} {
	stap_run $test no_load "ERROR: synthetic error.*" \
	    --runtime=$runtime $srcdir/$subdir/$test.stp
    } else {
	stap_run $test no_load "ERROR: synthetic error.*" $srcdir/$subdir/$test.stp
    }
}

