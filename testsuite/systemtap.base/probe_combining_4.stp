# TEST 4: Error isolation
# Error in one handler should not prevent subsequent handlers from running
# But the error should be reported at the end

probe begin {
    printf("handler 1: before error\n")
    error("intentional error in handler 1")
    printf("handler 1: after error (should not print)\n")
}

probe begin {
    printf("handler 2: runs despite error in handler 1\n")
}

probe begin {
    printf("handler 3: before error\n")
    error("intentional error in handler 3")
    printf("handler 3: after error (should not print)\n")
}

probe begin {
    printf("handler 4: runs despite error in handler 3\n")
    exit()
}
