global a, b

function foo(x) {
    if (x > 0)
        return x + foo(x-1)
    else
        return 0
}

probe begin(1) {
    next
    a = 4
}

probe begin(2) {
    ; /* null */
    a = 1 /* expr */
    { /* block */
        a = 2
    }
    for (i = 0; i < 5; i++) {
        if (i == 2) continue
        if (i == 3) break
    }
    
    b[1] = 1
    foreach (k in b) {
        a = b[k]
    }
    delete b

    try {
        error("oops")
    } catch {
        a = 3
    }
    
    foo(3)

    println("Done")
    exit()
}
