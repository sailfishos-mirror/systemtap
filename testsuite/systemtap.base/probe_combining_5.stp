# TEST 5: Comprehensive test
# Combining all features: types, next, error

probe begin {
    x = 1
    y = "a"
    printf("1: x=%d y=%s\n", x, y)
}

probe begin {
    x = "b"
    y = 2
    printf("2: x=%s y=%d\n", x, y)
    next
    printf("2: after next (should not print)\n")
}

probe begin {
    x = 3
    y = "c"
    printf("3: x=%d y=%s\n", x, y)
}

probe begin {
    x = "d"
    y = 4
    printf("4: x=%s y=%d\n", x, y)
    error("intentional error")
    printf("4: after error (should not print)\n")
}

probe begin {
    x = 5
    y = "e"
    printf("5: x=%d y=%s\n", x, y)
    exit()
}
