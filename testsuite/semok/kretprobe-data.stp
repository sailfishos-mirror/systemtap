#! stap -p2

# On kernels with kretprobe data-pouch, we have a tricky situation
# with data types.  Make sure a few different cases will work...
# path_lookup / do_path_lookup / kern_path_create gave way to
# path_lookupat / filename_lookup / kern_path.
probe kernel.function("kern_path_create").return !,
      kernel.function("do_path_lookup").return !,
      kernel.function("path_lookup").return !,
      kernel.function("path_lookupat").return !,
      kernel.function("filename_lookup").return !,
      kernel.function("kern_path").return
{
    if (@defined($path)) {
        println($path)
	println($path$)
    }
    else {
        println($nd)
	println($nd$)
    }
    println($$parms)
}
